<Window x:Class="FitnessTracker.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fitness Tracker Pro" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <Grid>
        <!-- Login -->
        <Border x:Name="LoginPanel" Background="White" Visibility="Visible">
            <StackPanel Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="FITNESS TRACKER PRO" FontSize="28" FontWeight="Bold" Foreground="#3F51B5" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <TextBox x:Name="LoginUsername" PlaceholderText="Логин" FontSize="14" Padding="10" Margin="0,0,0,15"/>
                <PasswordBox x:Name="LoginPassword" PlaceholderText="Пароль" FontSize="14" Padding="10" Margin="0,0,0,20"/>
                <Button Content="ВОЙТИ" Click="Login_Click" Background="#4CAF50" Foreground="White" Height="45" Margin="0,0,0,10"/>
                <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ" Click="Register_Click" Background="#2196F3" Foreground="White" Height="45"/>
                <TextBlock x:Name="LoginError" Foreground="#F44336" TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>
        
        <!-- Main Panel -->
        <Grid x:Name="MainPanel" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" Background="#3F51B5" Padding="15">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="FITNESS TRACKER PRO" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="WelcomeText" Foreground="#E8EAF6" VerticalAlignment="Center" Margin="30,0,0,0" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="🏠 Тренировки" Click="ShowWorkouts_Click" Background="#303F9F" Foreground="White" Margin="0,0,5,0"/>
                        <Button Content="📋 Цели" Click="ShowGoals_Click" Background="#303F9F" Foreground="White" Margin="0,0,5,0"/>
                        <Button Content="📁 Файлы" Click="ShowFiles_Click" Background="#303F9F" Foreground="White" Margin="0,0,10,0"/>
                        <Button Content="🚪 Выйти" Click="Logout_Click" Background="#F44336" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Grid.Row="1" Background="White" Padding="10" Margin="10,10,10,0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ Тренировка" Click="ShowAddWorkout_Click" Background="#4CAF50" Foreground="White" Margin="0,0,5,0"/>
                    <Button Content="+ Новая цель" Click="ShowAddGoal_Click" Background="#FF9800" Foreground="White" Margin="0,0,5,0"/>
                    <Button Content="📤 Загрузить файл" Click="ShowUploadFile_Click" Background="#2196F3" Foreground="White"/>
                </StackPanel>
            </Border>
            
            <Grid Grid.Row="2" Margin="10">
                <Border x:Name="WorkoutsPanel" Visibility="Visible" Background="White" CornerRadius="5" Padding="20">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="🏃 Мои тренировки" FontSize="20" FontWeight="Bold"/>
                        <ScrollViewer Grid.Row="1" Margin="0,15,0,0"><ItemsControl x:Name="WorkoutsList"/></ScrollViewer>
                    </Grid>
                </Border>
                <Border x:Name="GoalsPanel" Visibility="Hidden" Background="White" CornerRadius="5" Padding="20">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="🎯 Мои цели" FontSize="20" FontWeight="Bold"/>
                        <ScrollViewer Grid.Row="1" Margin="0,15,0,0"><ItemsControl x:Name="GoalsList"/></ScrollViewer>
                    </Grid>
                </Border>
                <Border x:Name="FilesPanel" Visibility="Hidden" Background="White" CornerRadius="5" Padding="20">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="📁 Мои файлы" FontSize="20" FontWeight="Bold"/>
                        <ScrollViewer Grid.Row="1" Margin="0,15,0,0"><ItemsControl x:Name="FilesList"/></ScrollViewer>
                    </Grid>
                </Border>
                
                <Border x:Name="PhotoViewerPanel" Visibility="Hidden" Background="White" CornerRadius="10" MaxWidth="900" MaxHeight="700" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border Background="#3F51B5" Padding="15" CornerRadius="10,10,0,0">
                            <Grid><TextBlock Text="📸 Фото прогресса" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                <Button Content="✕ Закрыть" Click="ClosePhotoViewer_Click" HorizontalAlignment="Right" Background="#F44336" Foreground="White"/></Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" Margin="20"><StackPanel>
                            <TextBlock Text="📷 Фото ДО" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FF5722"/>
                            <ItemsControl x:Name="BeforePhotosList"/><Separator Margin="0,20"/>
                            <TextBlock Text="📷 Фото ПОСЛЕ" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="#4CAF50"/>
                            <ItemsControl x:Name="AfterPhotosList"/></StackPanel>
                        </ScrollViewer>
                        <Border Grid.Row="2" Background="#F5F5F5" Padding="15" CornerRadius="0,0,10,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="📸 Загрузить ДО" Click="UploadBeforePhoto_Click" Background="#FF5722" Foreground="White" Margin="0,0,10,0"/>
                                <Button Content="📸 Загрузить ПОСЛЕ" Click="UploadAfterPhoto_Click" Background="#4CAF50" Foreground="White"/></StackPanel>
                        </Border></Grid>
                </Border>
            </Grid>
        </Grid>
        <Border x:Name="LoadingOverlay" Background="#80000000" Visibility="Hidden">
            <TextBlock Text="⏳ Загрузка..." Foreground="White" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>